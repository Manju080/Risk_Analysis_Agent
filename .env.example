# ── LLM ───────────────────────────────────────────
LLM_PROVIDER=gemini                  # gemini | haiku | ollama
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here   # optional, for haiku

# ── Vector DB ─────────────────────────────────────
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX=portfolio-news

# ── News ──────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── App ───────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
